{
  "frontend/**/*.{ts,tsx}": [
    "pnpm --filter frontend lint:fix",
    "pnpm --filter frontend format"
  ],
  "frontend/**/*.{json,md}": [
    "pnpm --filter frontend format"
  ],
  "backend/**/*.{ts}": [
    "pnpm --filter backend lint:fix",
    "pnpm --filter backend format"
  ],
  "backend/**/*.{json,md}": [
    "pnpm --filter backend format"
  ]
}
